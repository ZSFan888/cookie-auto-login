{
  "manifest_version": 3,
  "name": "Cookie 自动登录",
  "version": "2.0.0",
  "description": "B站 / 抖音 Cookie 提取与恢复，同步到 Cloudflare KV",
  "permissions": ["cookies", "activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://*.douyin.com/*",
    "*://*.snssdk.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/*", "*://*.douyin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
